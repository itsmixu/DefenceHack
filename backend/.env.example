# API keys for upstream data providers. Copy to .env and fill in.
# .env is gitignored; never commit real secrets.

# Get a free key at https://www.maanmittauslaitos.fi/en/maps-and-spatial-data/datasets-and-interfaces
MML_API_KEY=
FMI_API_KEY=
OPENCELLID_API_KEY=
N2YO_API_KEY=

# Optional overrides — used when an upstream renames its WFS layer or endpoint.
STATFIN_PAAVO_LAYER=
DIGIROAD_WFS_URL=
DIGIROAD_LAYER=

# MML terrain feature type name overrides (if WFS layer names change between releases).
MML_LAYER_SWAMP=
MML_LAYER_LAKE=
MML_LAYER_RIVER=
MML_LAYER_SEA=
MML_LAYER_BEDROCK=
MML_LAYER_SAND=
